# One key powers the whole workshop — the agent AND fenic both route through OpenRouter,
# so you can pick any model (openai/*, anthropic/*, qwen/*, ...). Get one: https://openrouter.ai/keys
# Optional: the cached notebook (nb02) renders with NO key at all.
# Do not commit real secrets.
OPENROUTER_API_KEY=

# Where fenic writes its local cache (Rung-2 coda only).
FENIC_WORK_DIR=./data/cache/fenic
